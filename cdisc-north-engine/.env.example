# ---- C-DISC North India Engine — Environment Variables ----
# Copy this file to `.env` and fill in real values.

# Google Places API key (for lead discovery)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# OpenAI API key (for personalised LLM-backed messaging)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP credentials for sending cold emails
# Example for Gmail with an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=outreach@cdisctechnologies.com
SMTP_PASSWORD=
SMTP_FROM_NAME=C-DISC Technologies
SMTP_REPLY_TO=cdiscpvtltd@gmail.com

# Database path (SQLite)
CDISC_DB_PATH=data/cdisc_pipeline.db

# Optional: set to "1" to enable verbose logging
CDISC_DEBUG=0
