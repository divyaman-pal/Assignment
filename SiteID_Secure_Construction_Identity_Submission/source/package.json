{
  "name": "SiteID",
  "version": "1.0.0",
  "private": true,
  "description": "Offline worker identity and wage-protection prototype for construction sites",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && xcodebuild clean && cd ..",
    "download-models": "node scripts/download-models.js",
    "postinstall": "node scripts/download-models.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-ml-kit/face-detection": "^1.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "date-fns": "^4.1.0",
    "onnxruntime-react-native": "^1.18.0",
    "react": "18.3.1",
    "react-native": "0.75.4",
    "react-native-blob-util": "^0.19.0",
    "react-native-fs": "^2.20.0",
    "react-native-image-resizer": "^1.4.5",
    "react-native-quick-sqlite": "^8.1.0",
    "react-native-safe-area-context": "^4.14.1",
    "react-native-screens": "^3.34.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/eslint-config": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
